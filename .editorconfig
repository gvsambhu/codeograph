root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.java]
indent_style = space
indent_size = 4

[*.py]
indent_style = space
indent_size = 4

[*.{xml,yml,yaml,json}]
indent_style = space
indent_size = 2

# Markdown: trailing spaces are intentional (hard line breaks)
[*.md]
trim_trailing_whitespace = false
