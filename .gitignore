MANIFEST

# Virtual environments
.venv/
venv/
env/
.env.local

# Secrets — never commit these
.env
# .env.example is committed (template with no real values)

# Generated Pydantic models — regenerated by `make schema-models`
# Committed intentionally; CI checks freshness. Do NOT add to gitignore.
# codeograph/graph/_generated_models.py  ← intentionally tracked

# Tool caches
.mypy_cache/
.ruff_cache/
.pytest_cache/
.cache/
htmlcov/
.coverage
coverage.xml

# IDE — personal files excluded; project-specific config tracked below
.idea/
.vscode/
# Track project formatter + test runner settings so all contributors use the same config
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
*.iml
*.ipr
*.iws
.DS_Store

# Codeograph runtime output — committed only for examples/ and tests/
out/
runs/

# JVM
*.class
hs_err_pid*.log
replay_pid*.log
# Maven build output
target/

# OS
Thumbs.db
desktop.ini
