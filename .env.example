# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# Required for LLM passes (DC2+). Not needed for --ast-only runs.
# CODEOGRAPH_ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides — defaults shown. See config.yaml for non-secret overrides.
# CODEOGRAPH_LLM_PROVIDER=anthropic
# CODEOGRAPH_LLM_MODEL=claude-sonnet-4-6
# CODEOGRAPH_LLM_CONCURRENCY=5
# CODEOGRAPH_MAX_PASS1_FAILURE_RATIO=0.10
