# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.
#
# .env holds SECRETS (API keys) plus the provider/model they pair with — that is all
# most setups need here. Every other non-secret knob (concurrency, cost ceilings,
# cache limits, per-stage model overrides, ...) lives in config.yaml; see that file
# for the full catalogue. No provider or key is needed for `--ast-only` runs.
#
# Fill in EXACTLY ONE provider block below. CODEOGRAPH_LLM_PROVIDER picks the active one.
# See docs/running-codeograph.md §1.3 for the walkthrough, docs/model-selection-and-cost.md
# for model choice + pricing.

# --- Provider block A: Anthropic (native) -----------------------------------
# CODEOGRAPH_LLM_PROVIDER=anthropic
# CODEOGRAPH_ANTHROPIC_API_KEY=sk-ant-...
# CODEOGRAPH_LLM_MODEL=claude-sonnet-4-6

# --- Provider block B: OpenRouter (aggregator) ------------------------------
# CODEOGRAPH_LLM_PROVIDER=openrouter
# CODEOGRAPH_OPENROUTER_API_KEY=sk-or-v1-...
# CODEOGRAPH_LLM_MODEL=deepseek/deepseek-v4-flash   # use the provider's EXACT model id

# --- Provider block C: any OpenAI-compatible endpoint -----------------------
# (Gemini via Google's OpenAI-compat surface, Groq, DeepSeek-direct, self-hosted, etc.)
# CODEOGRAPH_LLM_PROVIDER=openai_compatible
# CODEOGRAPH_OPENAI_COMPAT_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# CODEOGRAPH_OPENAI_COMPAT_API_KEY=...
# CODEOGRAPH_OPENAI_COMPAT_PROVIDER_LABEL=google-free   # ties endpoint to a prices.toml row
# CODEOGRAPH_LLM_MODEL=gemini-2.5-flash
